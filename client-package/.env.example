# ========================================
# LLM Provider Selection
# ========================================
# Options: "gemini", "mancer", or "openrouter"
LLM_PROVIDER=openrouter

# ========================================
# Gemini API Configuration
# ========================================
# Required only if LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# ========================================
# Mancer API Configuration
# ========================================
# Required only if LLM_PROVIDER=mancer
MANCER_API_KEY=your_mancer_api_key_here
MANCER_BASE_URL=https://neuro.mancer.tech/oai/v1
MANCER_DEFAULT_MODEL=mytholite

# ========================================
# OpenRouter API Configuration
# ========================================
# Required only if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemma-2-9b-it:free
OPENROUTER_SITE_URL=http://localhost:8001
OPENROUTER_SITE_NAME=Emotional-RAG-Backend

# ========================================
# Server Configuration
# ========================================
HOST=0.0.0.0
PORT=8001
WORKERS=1

# Memory
MAX_WORKING_MEMORY_SIZE=20
SUMMARIZE_AFTER_MESSAGES=20
DB_PATH=./data/sessions

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=3

# Phase 2: Feature Flags
ENABLE_CHROMADB=true
ENABLE_RERANKING=true
ENABLE_TRANSFORMER_EMOTIONS=true
ENABLE_REDIS=false
ENABLE_POSTGRESQL=false
ENABLE_METRICS=false
# Set to false to stop writing new messages to ChromaDB (RAG retrieval still works)
STORE_CHAT_EMBEDDINGS=false
# Set to false to disable knowledge_base ingestion on startup
INGEST_KNOWLEDGE_BASE=true
# Set to true to delete the ingestion manifest on startup, forcing a full re-ingest
# of all knowledge_base files. Useful for Docker deployments where the data/ volume
# may carry a stale manifest from a previous run.
RESET_INGESTION_ON_START=false

# Phase 2: ChromaDB Configuration
CHROMADB_PATH=./data/chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Phase 2: Reranking Configuration
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKING_CANDIDATES=50
RERANKING_TOP_K=10

# Phase 2: Advanced Emotion Detection
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
EMOTION_CONFIDENCE_THRESHOLD=0.5

# Phase 2: Redis Configuration
REDIS_URL=redis://localhost:6379/0
# TTL in seconds (30 minutes)
REDIS_TTL=1800
REDIS_MAX_CONNECTIONS=10

# Phase 2: PostgreSQL Configuration
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/emotional_rag
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# Token Budget (percentage allocation)
SYSTEM_TOKEN_PERCENT=20
RAG_TOKEN_PERCENT=25
HISTORY_TOKEN_PERCENT=35
RESPONSE_TOKEN_PERCENT=20

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
